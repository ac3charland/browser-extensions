{
    "extends": "@tsconfig/svelte/tsconfig.json",
    "compilerOptions": {
        "target": "ESNext",
        "useDefineForClassFields": true,
        "module": "ESNext",
        "resolveJsonModule": true,
        "allowJs": true,
        "checkJs": true,
        "isolatedModules": true,
        "moduleDetection": "force",
        "moduleResolution": "bundler",
        "strict": true,
        "noEmit": true,
        "types": ["svelte", "chrome", "node"]
    },
    "include": ["src/**/*.ts", "src/**/*.svelte", "vite.config.ts", "scripts/dev-build.mjs"]
}
