{
    "manifest_version": 3,
    "name": "Bookmark Express - Dev",
    "description": "This extension displays a list of your bookmarks filtered by instant search. That's it. Oh, and now you can edit them too.",
    "version": "9.0",
    "action": {
        "default_popup": "index.html"
    },
    "background": {
        "service_worker": "background.js"
    },
    "options_page": "index.html?page=options",

    "permissions": ["activeTab", "bookmarks", "storage", "favicon"],
    "icons": {
        "16": "images/icon16-dev.png",
        "48": "images/icon48-dev.png",
        "128": "images/icon128-dev.png"
    },
    "commands": {
        "_execute_action": {
            "suggested_key": {
                "windows": "Ctrl+Shift+K",
                "mac": "MacCtrl+Shift+K",
                "chromeos": "Ctrl+Shift+K",
                "linux": "Ctrl+Shift+K"
            }
        }
    }
}
