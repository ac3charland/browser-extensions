{
    "manifest_version": 3,
    "name": "Bookmark Express",
    "description": "This extension displays a list of your bookmarks filtered by instant search.",
    "version": "9.3",
    "action": {
        "default_popup": "index.html"
    },
    "background": {
        "service_worker": "background.js"
    },
    "options_page": "index.html?page=options",

    "permissions": ["activeTab", "bookmarks", "storage", "favicon"],
    "icons": {
        "16": "images/icon16.png",
        "48": "images/icon48.png",
        "128": "images/icon128.png"
    },
    "commands": {
        "_execute_action": {
            "suggested_key": {
                "windows": "Ctrl+Shift+L",
                "mac": "MacCtrl+Shift+L",
                "chromeos": "Ctrl+Shift+L",
                "linux": "Ctrl+Shift+L"
            }
        }
    }
}
